{
  "expo": {
    "name": "Call Pat",
    "slug": "call-pat-mobile",
    "version": "1.0.1",
    "scheme": "callpat",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is used to center the map and set the report pin when you choose Use GPS."
        }
      ],
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
