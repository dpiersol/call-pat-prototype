{
  "name": "@call-pat/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "predb:push": "node -e \"require('node:fs').mkdirSync('data',{recursive:true})\"",
    "db:push": "npx drizzle-kit push",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:studio": "npx drizzle-kit studio",
    "test": "npx tsx src/smoke.ts"
  },
  "dependencies": {
    "@call-pat/shared": "*",
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
