{
  "name": "call-pat-prototype",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,admin -c blue,green \"npm run dev -w @call-pat/api\" \"npm run dev -w @call-pat/web-admin\"",
    "dev:mobile": "npm run start -w @call-pat/mobile",
    "build": "npm run build -ws --if-present",
    "db:push": "npm run db:push -w @call-pat/api",
    "db:seed": "npm run db:seed -w @call-pat/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
